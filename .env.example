APP_ENV=development
# SECRET_KEY and WOPI_JWT_SECRET are auto-generated in development mode.
# In production, you MUST set these explicitly (use: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=
WOPI_JWT_SECRET=
LOG_LEVEL=INFO
SNIPPET_DEBUG=1
SERVER_NAME=

APP_URL=http://localhost:5001

COLLABORA_URL=http://localhost:9980
COLLABORA_INTERNAL_URL=
COLLABORA_PUBLIC_URL=
WOPI_HOST_URL=http://172.18.0.1:5001

MAIL_API_URL=http://mail-api:8800
MAIL_API_KEY=dev-mail-api-secret

IMAP_IDLE_FALLBACK_SECONDS=60
IMPORT_UPLOAD_RETENTION_HOURS=48
API_RATE_LIMIT_PER_MINUTE=60
MCP_ENABLED=true

GOOGLE_IMPORT_CLIENT_ID=
GOOGLE_IMPORT_CLIENT_SECRET=
